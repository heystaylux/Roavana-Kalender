generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id                  String           @id @default(cuid())
  name                String?
  email               String?          @unique
  emailVerified       DateTime?
  image               String?
  phone               String?
  onboardingDone      Boolean          @default(false)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  stripeCustomerId    String?          @unique
  subscriptionId      String?          @unique
  subscriptionPlan    SubscriptionPlan @default(FREE)
  subscriptionStatus  SubStatus        @default(INACTIVE)
  subscriptionEnd     DateTime?
  trialEnd            DateTime?

  accounts   Account[]
  sessions   Session[]
  properties Property[]
  icalFeeds  IcalFeed[]
  bookings   Booking[]
}

model Property {
  id        String     @id @default(cuid())
  userId    String
  name      String
  address   String
  city      String?
  country   String?
  emoji     String     @default("🏠")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  icalFeeds IcalFeed[]
  bookings  Booking[]
}

model IcalFeed {
  id         String     @id @default(cuid())
  userId     String
  propertyId String
  name       String
  url        String
  platform   Platform
  status     FeedStatus @default(PENDING)
  lastSynced DateTime?
  lastError  String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  bookings Booking[]
}

model Booking {
  id          String        @id @default(cuid())
  userId      String
  propertyId  String
  feedId      String?
  uid         String?
  platform    Platform
  guestName   String?
  guestEmail  String?
  checkIn     DateTime
  checkOut    DateTime
  guests      Int           @default(1)
  revenue     Float?
  currency    String        @default("EUR")
  status      BookingStatus @default(CONFIRMED)
  notes       String?
  source      BookingSource @default(ICAL)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  feed     IcalFeed? @relation(fields: [feedId], references: [id])

  @@unique([feedId, uid])
}

enum Platform {
  AIRBNB
  BOOKING
  TRAUMFERIENWOHNUNG
  MANUAL
  OTHER
}

enum FeedStatus {
  PENDING
  OK
  ERROR
  SYNCING
}

enum BookingStatus {
  CONFIRMED
  PENDING
  CANCELLED
}

enum BookingSource {
  ICAL
  MANUAL
  API
}

enum SubscriptionPlan {
  FREE
  STARTER
  PRO
  BUSINESS
}

enum SubStatus {
  INACTIVE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
}
